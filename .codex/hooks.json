{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|ApplyPatch|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/ai-after-work.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/ai-after-work.sh"
          }
        ]
      }
    ]
  }
}
